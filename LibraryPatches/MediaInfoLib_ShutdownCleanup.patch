+namespace
+{
+    template <class T>
+    void ClearAndFree(T& container)
+    {
+        T empty;
+        container.swap(empty);
+    }
+}
+
 //***************************************************************************
 // Constructor/Destructor
 //***************************************************************************
 
+void MediaInfo_Config::ShutdownCleanup()
+{
+    CriticalSectionLocker CSL(CS);
+
+    // Release heavy caches to keep CRT leak reports clean at shutdown.
+    ClearAndFree(Trace_Modificators);
+    ClearAndFree(CustomMapping);
+    ClearAndFree(Language);
+    ClearAndFree(Custom_View);
+    ClearAndFree(Custom_View_Replace);
+    ClearAndFree(SubFile_Config);
+
+    ClearAndFree(Container);
+    for (size_t Format=0; Format<InfoCodecID_Format_Max; Format++)
+        for (size_t StreamKind=0; StreamKind<Stream_Max; StreamKind++)
+            ClearAndFree(CodecID[Format][StreamKind]);
+    ClearAndFree(Format);
+    ClearAndFree(Codec);
+    for (size_t Format=0; Format<InfoLibrary_Format_Max; Format++)
+        ClearAndFree(Library[Format]);
+    ClearAndFree(Iso639_1);
+    ClearAndFree(Iso639_2);
+    for (size_t StreamKind=0; StreamKind<Stream_Max; StreamKind++)
+        ClearAndFree(Info[StreamKind]);
+}
